<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Owner Dashboard - Pharmacy Management</title>
    <!-- Modern Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --primary: #0f766e;
        --primary-light: #14b8a6;
        --accent: #6366f1;
        --bg: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --error: #ef4444;
        --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
          0 4px 6px -2px rgba(0, 0, 0, 0.05);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", sans-serif;
        background-color: var(--bg);
        color: var(--text-main);
        min-height: 100vh;
        padding: 15px;
        position: relative;
        overflow-x: hidden;
      }

      /* Consistent Background Accents */
      .bg-circle {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        z-index: -1;
        opacity: 0.15;
      }
      .circle-1 {
        width: 400px;
        height: 400px;
        background: var(--primary);
        top: -100px;
        left: -100px;
      }
      .circle-2 {
        width: 300px;
        height: 300px;
        background: var(--accent);
        bottom: -50px;
        right: -50px;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
      }

      /* Header Styling */
      .header {
        background: white;
        padding: 30px 20px;
        border-radius: 24px;
        box-shadow: var(--card-shadow);
        text-align: center;
        margin-bottom: 25px;
        border: 1px solid rgba(255, 255, 255, 0.8);
      }

      .header h1 {
        font-size: 24px;
        font-weight: 800;
        color: var(--primary);
        letter-spacing: -0.025em;
        margin-bottom: 8px;
      }

      .header p {
        color: var(--text-muted);
        font-size: 15px;
        font-weight: 500;
      }

      /* Welcome Section */
      .welcome-card {
        background: linear-gradient(135deg, var(--primary) 0%, #0d9488 100%);
        padding: 30px;
        border-radius: 24px;
        color: white;
        margin-bottom: 30px;
        box-shadow: 0 20px 25px -5px rgba(15, 118, 110, 0.2);
        position: relative;
        overflow: hidden;
      }

      .welcome-card h2 {
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 10px;
      }

      .welcome-card p {
        opacity: 0.9;
        font-size: 15px;
        line-height: 1.6;
      }

      /* Menu Grid (The Core Business Area) */
      .menu-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 40px;
      }

      .menu-card {
        background: white;
        padding: 30px 20px;
        border-radius: 24px;
        text-decoration: none;
        color: var(--text-main);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        box-shadow: var(--card-shadow);
        border: 1px solid #f1f5f9;
      }

      .menu-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
        border-color: var(--primary-light);
      }

      .menu-card:active {
        transform: translateY(-2px);
      }

      .menu-card .icon {
        font-size: 44px;
        margin-bottom: 20px;
        background: #f1f5f9;
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 20px;
        transition: all 0.3s;
      }

      .menu-card:hover .icon {
        background: #f0fdfa;
        transform: scale(1.1) rotate(5deg);
      }

      .menu-card h3 {
        font-size: 18px;
        font-weight: 700;
        margin-bottom: 10px;
        color: var(--text-main);
      }

      .menu-card p {
        font-size: 13px;
        color: var(--text-muted);
        line-height: 1.5;
      }

      /* Logout Button */
      .logout-container {
        text-align: center;
        margin-bottom: 40px;
      }

      .logout-btn {
        background: #fee2e2;
        color: #dc2626;
        border: 1px solid #fecaca;
        padding: 16px 40px;
        border-radius: 16px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 700;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 10px;
      }

      .logout-btn:hover {
        background: #fecaca;
        transform: scale(1.05);
      }

      /* Footer */
      .footer {
        text-align: center;
        padding: 30px;
        color: var(--text-muted);
        font-size: 13px;
        font-weight: 500;
      }

      /* Responsiveness - Tablet */
      @media (max-width: 1024px) {
        .menu-grid {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      /* Responsiveness - Phone */
      @media (max-width: 640px) {
        body {
          padding: 10px;
        }
        .header {
          padding: 25px 15px;
          border-radius: 20px;
        }
        .welcome-card {
          padding: 25px;
          border-radius: 20px;
        }
        .menu-grid {
          grid-template-columns: 1fr; /* Single column for easy thumb tapping */
          gap: 15px;
        }
        .menu-card {
          padding: 25px;
          flex-direction: row; /* Horizontal layout on mobile for better space usage */
          text-align: left;
          align-items: center;
          gap: 20px;
        }
        .menu-card .icon {
          width: 60px;
          height: 60px;
          font-size: 30px;
          margin-bottom: 0;
          flex-shrink: 0;
        }
        .menu-card-text {
          flex: 1;
        }
        .logout-btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>

    <div class="container">
      <!-- Header -->
      <header class="header">
        <h1>🏥 Pharmacy Management</h1>
        <p>System Administrator Dashboard</p>
      </header>

      <!-- Content -->
      <main class="content">
        <div class="welcome-card">
          <h2>👋 Hello, <%= user.name %>!</h2>
          <p>
            You are currently managing the pharmacy as an
            <strong><%= user.role %></strong>
          </p>
        </div>

        <!-- Mobile Optimized Menu Grid -->
        <div class="menu-grid">
          <a href="/medicines" class="menu-card">
            <div class="icon">💊</div>
            <div class="menu-card-text">
              <h3>Medicines</h3>
              <p>Add, edit inventory and track stock levels</p>
            </div>
          </a>

          <a href="/batches" class="menu-card">
            <div class="icon">📦</div>
            <div class="menu-card-text">
              <h3>Batches</h3>
              <p>Track expiry dates and batch numbers</p>
            </div>
          </a>

          <a href="/suppliers" class="menu-card">
            <div class="icon">🏢</div>
            <div class="menu-card-text">
              <h3>Suppliers</h3>
              <p>Manage supplier profiles and purchases</p>
            </div>
          </a>

          <a href="/sales" class="menu-card">
            <div class="icon">💰</div>
            <div class="menu-card-text">
              <h3>Sales</h3>
              <p>Daily reports and transaction history</p>
            </div>
          </a>

          <a href="/reports" class="menu-card">
            <div class="icon">📊</div>
            <div class="menu-card-text">
              <h3>Analytics</h3>
              <p>Profit margins and trends analytics</p>
            </div>
          </a>

          <a href="/users" class="menu-card">
            <div class="icon">👥</div>
            <div class="menu-card-text">
              <h3>Staff Users</h3>
              <p>Manage employee access and accounts</p>
            </div>
          </a>
        </div>

        <!-- Logout Section -->
        <div class="logout-container">
          <form action="/auth/logout" method="GET" style="display: inline">
            <button type="submit" class="logout-btn">🚪 Logout</button>
          </form>
        </div>
      </main>

      <footer class="footer">
        <p>Pharmacy Management System &copy; 2024</p>
      </footer>
    </div>
  </body>
</html>
