<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Manage Suppliers - Pharmacy Management</title>
    <!-- Modern Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --primary: #0f766e;
        --primary-light: #14b8a6;
        --accent: #6366f1;
        --bg: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --success: #10b981;
        --warning: #f59e0b;
        --error: #ef4444;
        --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1),
          0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", sans-serif;
        background-color: var(--bg);
        color: var(--text-main);
        line-height: 1.5;
        padding: 20px;
        position: relative;
        min-height: 100vh;
      }

      /* Background Accents */
      .bg-circle {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        z-index: -1;
        opacity: 0.1;
      }
      .circle-1 {
        width: 400px;
        height: 400px;
        background: var(--primary);
        top: -100px;
        left: -100px;
      }
      .circle-2 {
        width: 300px;
        height: 300px;
        background: var(--accent);
        bottom: -50px;
        right: -50px;
      }

      .container {
        max-width: 1300px;
        margin: 0 auto;
      }

      .header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 25px;
      }

      h2 {
        color: var(--primary);
        font-size: 24px;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .header-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      /* Statistics Grid */
      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 15px;
        margin-bottom: 25px;
      }

      .stat-card {
        background: white;
        padding: 20px;
        border-radius: 16px;
        box-shadow: var(--card-shadow);
        text-align: center;
        border-bottom: 4px solid transparent;
      }

      .stat-card h3 {
        font-size: 26px;
        font-weight: 800;
        margin-bottom: 5px;
      }
      .stat-card p {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
      }

      .stat-total {
        border-color: var(--primary);
        color: var(--primary);
      }
      .stat-batches {
        border-color: var(--accent);
        color: var(--accent);
      }
      .stat-investment {
        border-color: var(--success);
        color: var(--success);
      }

      /* Action Bar */
      .action-bar {
        background: white;
        padding: 20px;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        margin-bottom: 25px;
      }

      .search-box {
        display: flex;
        gap: 10px;
        width: 100%;
      }

      .search-box input {
        flex: 1;
        padding: 12px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-family: inherit;
        background: #f8fafc;
      }

      .search-box input:focus {
        outline: none;
        border-color: var(--primary);
        background: white;
      }

      /* Buttons */
      .btn {
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        border: none;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      .btn-primary {
        background: var(--primary);
        color: white;
      }
      .btn-primary:hover {
        background: var(--primary-light);
      }

      .btn-success {
        background: var(--success);
        color: white;
      }
      .btn-dashboard {
        background: #f1f5f9;
        color: var(--text-main);
      }
      .btn-dashboard:hover {
        background: #e2e8f0;
      }

      /* Table Styles */
      .table-container {
        background: white;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        overflow-x: auto;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
      }
      th {
        background: #f8fafc;
        padding: 16px;
        text-align: left;
        color: var(--text-muted);
        font-weight: 700;
        font-size: 12px;
        text-transform: uppercase;
        border-bottom: 2px solid #f1f5f9;
      }
      td {
        padding: 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
      }

      tr:hover td {
        background-color: #fcfdfe;
      }

      .badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        background: #f1f5f9;
        color: var(--primary);
      }

      .btn-sm {
        padding: 6px 12px;
        font-size: 12px;
        border-radius: 8px;
      }
      .btn-edit {
        background: #fef3c7;
        color: #92400e;
      }
      .btn-delete {
        background: #fee2e2;
        color: #b91c1c;
      }
      .btn-view {
        background: #e0f2fe;
        color: #0369a1;
      }

      /* Alerts */
      .alert {
        padding: 14px 18px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        border-left: 5px solid;
      }
      .alert-success {
        background: #ecfdf5;
        color: #065f46;
        border-color: #10b981;
      }
      .alert-error {
        background: #fef2f2;
        color: #991b1b;
        border-color: #ef4444;
      }

      /* Modal Styling */
      .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        inset: 0;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(4px);
        align-items: center;
        justify-content: center;
        padding: 20px;
      }

      .modal-content {
        background: white;
        padding: 30px;
        border-radius: 24px;
        width: 100%;
        max-width: 650px;
        max-height: 85vh;
        overflow-y: auto;
        position: relative;
        animation: modalSlide 0.3s ease-out;
      }

      @keyframes modalSlide {
        from {
          opacity: 0;
          transform: translateY(20px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .close {
        position: absolute;
        right: 20px;
        top: 20px;
        font-size: 24px;
        cursor: pointer;
        color: var(--text-muted);
      }

      /* Modal Table Styles */
      .modal-details-table {
        width: 100%;
        border-collapse: collapse;
      }

      .modal-details-table tr {
        border-bottom: 1px solid #f1f5f9;
      }

      .modal-details-table td {
        padding: 12px 8px;
        border: none;
        text-align: left !important;
        vertical-align: top;
      }

      .modal-details-table td:first-child {
        font-weight: 700;
        color: var(--text-muted);
        width: 120px;
      }

      .modal-details-table td:last-child {
        text-align: left !important;
        color: var(--text-main);
      }

      /* Batch Card Styles - Vertical Layout */
      .batch-card {
        background: #f8fafc;
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 12px;
        border: 1px solid #e2e8f0;
      }

      .batch-card-item {
        display: flex;
        margin-bottom: 6px;
        font-size: 13px;
      }

      .batch-card-label {
        font-weight: 700;
        color: var(--text-muted);
        width: 70px;
        flex-shrink: 0;
      }

      .batch-card-value {
        color: var(--text-main);
      }

      .batch-card:last-child {
        margin-bottom: 0;
      }

      /* Responsive Table */
      @media (max-width: 1024px) {
        .main-table,
        .main-table thead,
        .main-table tbody,
        .main-table th,
        .main-table td,
        .main-table tr {
          display: block;
        }
        .main-table thead {
          display: none;
        }
        .main-table tr {
          border-bottom: 2px solid #f1f5f9;
          padding: 15px;
        }
        .main-table td {
          border: none;
          padding: 8px 0 8px 140px;
          position: relative;
          min-height: 35px;
          text-align: right;
        }
        .main-table td:before {
          content: attr(data-label);
          position: absolute;
          left: 0;
          width: 130px;
          text-align: left;
          font-weight: 700;
          color: var(--text-muted);
          font-size: 11px;
          text-transform: uppercase;
        }
        .header-flex {
          flex-direction: column;
          align-items: flex-start;
        }
      }

      /* Mobile Modal Fix */
      @media (max-width: 600px) {
        .modal-content {
          padding: 20px;
        }
        .modal-details-table td {
          display: block;
          width: 100%;
          padding: 8px 0;
        }
        .modal-details-table td:first-child {
          width: 100%;
          padding-bottom: 4px;
        }
        .modal-details-table tr {
          display: block;
          margin-bottom: 12px;
          border-bottom: 1px solid #f1f5f9;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>

    <div class="container">
      <header class="header-flex">
        <h2><span>🏢</span> Supplier Management</h2>
        <div class="header-buttons">
          <a href="/suppliers/create" class="btn btn-success"
            >+ Add New Supplier</a
          >
          <a href="/dashboard" class="btn btn-dashboard">← Back to Dashboard</a>
        </div>
      </header>

      <!-- Alerts -->
      <% if (success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success"><%= success_msg %></div>
      <% } %> <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-error"><%= error_msg %></div>
      <% } %>

      <!-- Statistics Cards -->
      <div class="stats">
        <div class="stat-card stat-total">
          <h3><%= stats ? stats.total_suppliers : 0 %></h3>
          <p>Total Suppliers</p>
        </div>
        <div class="stat-card stat-batches">
          <h3><%= stats ? (stats.total_batches || 0) : 0 %></h3>
          <p>Total Batches</p>
        </div>
        <div class="stat-card stat-investment">
          <h3>
            <%= stats ? parseFloat(stats.total_investment || 0).toLocaleString()
            : 0 %> ETB
          </h3>
          <p>Total Investment</p>
        </div>
      </div>

      <!-- Search Section -->
      <div class="action-bar">
        <form method="GET" action="/suppliers" class="search-box">
          <input
            type="text"
            name="search"
            placeholder="Search by name, email, phone..."
            value="<%= typeof search !== 'undefined' ? search : '' %>"
          />
          <button type="submit" class="btn btn-primary">Search</button>
          <% if (typeof search !== 'undefined' && search) { %>
          <a href="/suppliers" class="btn btn-dashboard">Clear Filter</a>
          <% } %>
        </form>
      </div>

      <!-- Suppliers Table -->
      <div class="table-container">
        <table class="main-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Contact Info</th>
              <th>Address</th>
              <th>Batches</th>
              <th>Inventory</th>
              <th>Investment</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!suppliers || suppliers.length === 0) { %>
            <tr>
              <td
                colspan="7"
                style="
                  text-align: center;
                  padding: 50px;
                  color: var(--text-muted);
                "
              >
                No suppliers found.<br />
                <a
                  href="/suppliers/create"
                  style="color: var(--primary); font-weight: 700"
                  >Add your first supplier</a
                >
              </td>
            </tr>
            <% } else { %> <% suppliers.forEach(function(supplier) { %>
            <tr>
              <td data-label="Name"><strong><%= supplier.name %></strong></td>
              <td data-label="Contact">
                <div style="font-size: 13px"><%= supplier.email || '-' %></div>
                <div style="font-size: 12px; color: var(--text-muted)">
                  <%= supplier.phone || '-' %>
                </div>
              </td>
              <td data-label="Address">
                <span style="font-size: 12px"
                  ><%= supplier.address ? supplier.address.substring(0, 40) :
                  '-' %><%= supplier.address && supplier.address.length > 40 ?
                  '...' : '' %></span
                >
              </td>
              <td data-label="Batches">
                <span class="badge"><%= supplier.batch_count || 0 %></span>
              </td>
              <td data-label="Inventory">
                <%= supplier.total_quantity || 0 %> Units
              </td>
              <td data-label="Investment">
                <%= parseFloat(supplier.total_purchase_value ||
                0).toLocaleString() %> ETB
              </td>
              <td data-label="Actions">
                <div style="display: flex; gap: 4px; justify-content: flex-end">
                  <button
                    class="btn btn-sm btn-view"
                    onclick="viewSupplierDetails(<%= supplier.id %>)"
                  >
                    Details
                  </button>
                  <a
                    href="/suppliers/edit/<%= supplier.id %>"
                    class="btn btn-sm btn-edit"
                    >Edit</a
                  >
                  <form
                    action="/suppliers/delete/<%= supplier.id %>"
                    method="POST"
                    style="display: inline"
                    onsubmit="return confirm('Delete this supplier?')"
                  >
                    <button type="submit" class="btn btn-sm btn-delete">
                      Del
                    </button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %> <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Details Modal -->
    <div id="supplierModal" class="modal">
      <div class="modal-content">
        <span class="close" onclick="closeModal()">&times;</span>
        <h3
          style="
            color: var(--primary);
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 10px;
            margin-bottom: 20px;
          "
        >
          Supplier Profile
        </h3>
        <div id="supplierDetails"></div>
      </div>
    </div>

    <script>
      function viewSupplierDetails(id) {
        fetch("/suppliers/details/" + id)
          .then(function (res) {
            return res.json();
          })
          .then(function (data) {
            var supplier = data.supplier;
            var batches = data.recentBatches;
            var batchesHtml = "";

            if (batches && batches.length > 0) {
              batchesHtml =
                '<h4 style="margin: 20px 0 10px; font-size: 15px;">Recent Batches:</h4>';

              for (var i = 0; i < batches.length; i++) {
                var b = batches[i];
                batchesHtml +=
                  '<div class="batch-card">' +
                  '<div class="batch-card-item">' +
                  '<span class="batch-card-label">Medicine:</span>' +
                  '<span class="batch-card-value">' +
                  b.medicine_name +
                  "</span>" +
                  "</div>" +
                  '<div class="batch-card-item">' +
                  '<span class="batch-card-label">Batch:</span>' +
                  '<span class="batch-card-value">' +
                  b.batch_no +
                  "</span>" +
                  "</div>" +
                  '<div class="batch-card-item">' +
                  '<span class="batch-card-label">Qty:</span>' +
                  '<span class="batch-card-value">' +
                  b.quantity +
                  "</span>" +
                  "</div>" +
                  '<div class="batch-card-item">' +
                  '<span class="batch-card-label">Date:</span>' +
                  '<span class="batch-card-value">' +
                  new Date(b.created_at).toLocaleDateString() +
                  "</span>" +
                  "</div>" +
                  "</div>";
              }
            } else {
              batchesHtml =
                "<p style='font-size: 13px; color: #64748b; margin-top: 15px;'>No batches linked to this supplier yet.</p>";
            }

            document.getElementById("supplierDetails").innerHTML =
              '<table class="modal-details-table">' +
              "<tr><td><strong>Name:</strong></td><td>" +
              supplier.name +
              "</td></tr>" +
              "<tr><td><strong>Email:</strong></td><td>" +
              (supplier.email || "-") +
              "</td></tr>" +
              "<tr><td><strong>Phone:</strong></td><td>" +
              (supplier.phone || "-") +
              "</td></tr>" +
              "<tr><td><strong>Address:</strong></td><td>" +
              (supplier.address || "-") +
              "</td></tr>" +
              "<tr><td><strong>Total Batches:</strong></td><td>" +
              (supplier.batch_count || 0) +
              "</td></tr>" +
              "<tr><td><strong>Total Quantity:</strong></td><td>" +
              (supplier.total_quantity || 0) +
              " units</td></tr>" +
              '<tr style="border-top: 1px solid #f1f5f9;"><td><strong>Total Investment:</strong></td><td style="color: var(--success); font-weight: 700;"> ' +
              parseFloat(supplier.total_purchase_value || 0).toLocaleString() +
              "ETB" +
              "</td></tr>" +
              "<tr><td><strong>Joined Date:</strong></td><td>" +
              new Date(supplier.created_at).toLocaleDateString() +
              "</td></tr>" +
              "</table>" +
              batchesHtml;

            document.getElementById("supplierModal").style.display = "flex";
          })
          .catch(function (error) {
            console.error("Error:", error);
            alert("Could not load supplier details");
          });
      }

      function closeModal() {
        document.getElementById("supplierModal").style.display = "none";
      }

      window.onclick = function (event) {
        var modal = document.getElementById("supplierModal");
        if (event.target == modal) {
          closeModal();
        }
      };
    </script>
  </body>
</html>
