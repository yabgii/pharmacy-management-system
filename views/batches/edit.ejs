<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Batch - Pharmacy Management</title>
    <!-- Modern Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0f766e;
            --primary-light: #14b8a6;
            --accent: #6366f1;
            --bg: #f8fafc;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border: #e2e8f0;
            --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--text-main);
            line-height: 1.5;
            padding: 20px;
            position: relative;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* Background Accents */
        .bg-circle {
            position: fixed;
            border-radius: 50%;
            filter: blur(80px);
            z-index: -1;
            opacity: 0.1;
        }
        .circle-1 { width: 400px; height: 400px; background: var(--primary); top: -100px; left: -100px; }
        .circle-2 { width: 300px; height: 300px; background: var(--accent); bottom: -50px; right: -50px; }

        .container {
            max-width: 700px;
            width: 100%;
            background: white;
            padding: 40px;
            border-radius: 24px;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(255, 255, 255, 0.8);
        }

        h2 {
            color: var(--primary);
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 30px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 2px solid #f1f5f9;
            padding-bottom: 15px;
        }

        /* Form Grid */
        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        /* Span full width for specific inputs */
        .full-width {
            grid-column: span 2;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-main);
            font-weight: 600;
            font-size: 13px;
        }

        input, select {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid var(--border);
            border-radius: 12px;
            font-family: inherit;
            font-size: 14px;
            background: #f8fafc;
            transition: all 0.2s;
        }

        input:focus, select:focus {
            outline: none;
            border-color: var(--primary);
            background: white;
            box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1);
        }

        .btn-group {
            margin-top: 25px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        button {
            background: var(--primary);
            color: white;
            padding: 14px;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 4px 6px -1px rgba(15, 118, 110, 0.2);
        }

        button:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(15, 118, 110, 0.3);
        }

        .btn-cancel {
            background: #f1f5f9;
            color: var(--text-muted);
            text-decoration: none;
            text-align: center;
            padding: 12px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 14px;
            transition: all 0.2s;
        }

        .btn-cancel:hover {
            background: #e2e8f0;
            color: var(--text-main);
        }

        /* Responsive Adjustments */
        @media (max-width: 600px) {
            .container {
                padding: 25px;
            }
            .form-grid {
                grid-template-columns: 1fr;
            }
            .full-width {
                grid-column: span 1;
            }
            h2 {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>

    <div class="container">
        <h2>✏️ Edit Batch Details</h2>
        
        <form action="/batches/edit/<%= batch.id %>" method="POST">
            <div class="form-grid">
                <!-- Medicine Selection -->
                <div class="form-group full-width">
                    <label>Medicine *</label>
                    <select name="medicine_id" required>
                        <% medicines.forEach(m => { %>
                            <option value="<%= m.id %>" <%= batch.medicine_id == m.id ? 'selected' : '' %>>
                                <%= m.name %> (<%= m.unit %>)
                            </option>
                        <% }) %>
                    </select>
                </div>
                
                <!-- Supplier Selection -->
                <div class="form-group full-width">
                    <label>Supplier</label>
                    <select name="supplier_id">
                        <option value="">-- Select Supplier --</option>
                        <% suppliers.forEach(s => { %>
                            <option value="<%= s.id %>" <%= batch.supplier_id == s.id ? 'selected' : '' %>>
                                <%= s.name %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                
                <!-- Batch Number -->
                <div class="form-group">
                    <label>Batch Number *</label>
                    <input type="text" name="batch_no" value="<%= batch.batch_no %>" placeholder="e.g. B-101" required>
                </div>
                
                <!-- Quantity -->
                <div class="form-group">
                    <label>Quantity *</label>
                    <input type="number" name="quantity" value="<%= batch.quantity %>" required min="0">
                </div>
                
                <!-- Cost Price -->
                <div class="form-group">
                    <label>Cost Price *</label>
                    <input type="number" step="0.01" name="cost_price" value="<%= batch.cost_price %>" required>
                </div>
                
                <!-- Selling Price -->
                <div class="form-group">
                    <label>Selling Price *</label>
                    <input type="number" step="0.01" name="selling_price" value="<%= batch.selling_price %>" required>
                </div>
                
                <!-- Manufacture Date -->
                <div class="form-group">
                    <label>Manufacture Date</label>
                    <input type="date" name="manufacture_date" value="<%= batch.manufacture_date ? batch.manufacture_date.toISOString().split('T')[0] : '' %>">
                </div>
                
                <!-- Expiry Date -->
                <div class="form-group">
                    <label>Expiry Date *</label>
                    <input type="date" name="expiry_date" value="<%= batch.expiry_date.toISOString().split('T')[0] %>" required>
                </div>
            </div>
            
            <div class="btn-group">
                <button type="submit">Update Batch Information</button>
                <a href="/batches" class="btn-cancel">Cancel and Return</a>
            </div>
        </form>
    </div>
</body>
</html>