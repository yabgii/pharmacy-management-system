<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Medicine - Pharmacy Management</title>
    <!-- Modern Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --primary: #0f766e;
        --primary-light: #14b8a6;
        --accent: #6366f1;
        --bg: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --success: #10b981;
        --border: #e2e8f0;
        --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
          0 4px 6px -2px rgba(0, 0, 0, 0.05);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", sans-serif;
        background-color: var(--bg);
        color: var(--text-main);
        line-height: 1.5;
        padding: 20px;
        position: relative;
        min-height: 100vh;
      }

      /* Background Accents */
      .bg-circle {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        z-index: -1;
        opacity: 0.1;
      }
      .circle-1 {
        width: 400px;
        height: 400px;
        background: var(--primary);
        top: -100px;
        left: -100px;
      }
      .circle-2 {
        width: 300px;
        height: 300px;
        background: var(--accent);
        bottom: -50px;
        right: -50px;
      }

      .container {
        max-width: 850px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 24px;
        box-shadow: var(--card-shadow);
        border: 1px solid rgba(255, 255, 255, 0.8);
      }

      .header-area {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 20px;
      }

      h2 {
        color: var(--primary);
        font-size: 24px;
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .btn-back {
        text-decoration: none;
        color: var(--text-muted);
        font-size: 14px;
        font-weight: 600;
        transition: color 0.2s;
      }

      .btn-back:hover {
        color: var(--primary);
      }

      h3 {
        color: var(--text-main);
        margin: 30px 0 20px;
        font-size: 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      h3::before {
        content: "";
        width: 4px;
        height: 18px;
        background: var(--primary-light);
        border-radius: 10px;
        display: inline-block;
      }

      /* Responsive Grid System */
      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }

      .form-group {
        margin-bottom: 18px;
      }

      .form-group.full-width {
        grid-column: span 2;
      }

      label {
        display: block;
        margin-bottom: 8px;
        color: var(--text-main);
        font-weight: 600;
        font-size: 13px;
      }

      input,
      select,
      textarea {
        width: 100%;
        padding: 12px 16px;
        border: 1.5px solid var(--border);
        border-radius: 12px;
        font-family: inherit;
        font-size: 14px;
        background: #f8fafc;
        transition: all 0.2s;
      }

      input:focus,
      select:focus,
      textarea:focus {
        outline: none;
        border-color: var(--primary);
        background: white;
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1);
      }

      .new-fields-container {
        grid-column: span 2;
        background: #f0fdfa;
        padding: 20px;
        border-radius: 16px;
        margin-top: 5px;
        border: 1px dashed var(--primary-light);
        display: none; /* Controlled by JS */
      }

      .btn-submit {
        background: var(--primary);
        color: white;
        border: none;
        padding: 16px;
        border-radius: 14px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 700;
        width: 100%;
        margin-top: 30px;
        transition: all 0.3s;
        box-shadow: 0 4px 6px -1px rgba(15, 118, 110, 0.2);
      }

      .btn-submit:hover {
        background: var(--primary-light);
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(15, 118, 110, 0.3);
      }

      hr {
        grid-column: span 2;
        border: none;
        border-top: 1px solid #f1f5f9;
        margin: 10px 0;
      }

      /* Responsive Adjustments */
      @media (max-width: 768px) {
        .container {
          padding: 25px;
        }
        .form-grid {
          grid-template-columns: 1fr;
        }
        .form-group.full-width {
          grid-column: span 1;
        }
        .new-fields-container {
          grid-column: span 1;
        }
        hr {
          grid-column: span 1;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>

    <div class="container">
      <div class="header-area">
        <h2><span>➕</span> Add New Medicine</h2>
        <a href="/medicines" class="btn-back">← Back to Inventory</a>
      </div>

      <form action="/medicines/create" method="POST">
        <!-- MEDICINE INFO -->
        <h3>Medicine Information</h3>
        <div class="form-grid">
          <div class="form-group">
            <label>Medicine Name *</label>
            <input
              type="text"
              name="name"
              placeholder="e.g., Paracetamol 500mg"
              required
            />
          </div>

          <div class="form-group">
            <label>Generic Name</label>
            <input
              type="text"
              name="generic_name"
              placeholder="e.g., Acetaminophen"
            />
          </div>

          <div class="form-group">
            <label>Category</label>
            <input
              type="text"
              name="category"
              placeholder="e.g., Pain Relief"
            />
          </div>

          <div class="form-group">
            <label>Unit </label>
            <input
              type="text"
              name="unit"
              placeholder="e.g., Tablet, Strip, Bottle"
              required
            />
          </div>

          <div class="form-group full-width">
            <label>Minimum Stock Alert Level *</label>
            <input
              type="number"
              name="min_stock_level"
              placeholder="Notify me when stock falls below..."
              required
            />
          </div>
        </div>

        <hr />

        <!-- MANUFACTURER INFO -->
        <h3>Manufacturer Information</h3>
        <div class="form-grid">
          <div class="form-group full-width">
            <label>Select Manufacturer</label>
            <select name="manufacturer_id" id="manufacturerSelect">
              <option value="">Choose Existing Manufacturer</option>
              <% if (manufacturers && manufacturers.length > 0) { %> <%
              manufacturers.forEach(m => { %>
              <option value="<%= m.id %>"><%= m.name %></option>
              <% }) %> <% } %>
              <option
                value="new"
                style="font-weight: bold; color: var(--primary)"
              >
                + Create New Manufacturer
              </option>
            </select>
          </div>

          <div id="newManufacturerFields" class="new-fields-container">
            <div class="form-grid">
              <div class="form-group full-width">
                <label>Manufacturer Name *</label>
                <input
                  type="text"
                  name="new_manufacturer_name"
                  placeholder="e.g., GSK Pharma"
                />
              </div>
              <div class="form-group">
                <label>Email</label>
                <input
                  type="email"
                  name="new_manufacturer_email"
                  placeholder="contact@mfg.com"
                />
              </div>
              <div class="form-group">
                <label>Phone</label>
                <input
                  type="text"
                  name="new_manufacturer_phone"
                  placeholder="Phone number"
                />
              </div>
            </div>
          </div>
        </div>

        <hr />

        <!-- SUPPLIER INFO -->
        <h3>Supplier Information</h3>
        <div class="form-grid">
          <div class="form-group full-width">
            <label>Select Supplier</label>
            <select name="supplier_id" id="supplierSelect">
              <option value="">Choose Existing Supplier</option>
              <% if (suppliers && suppliers.length > 0) { %> <%
              suppliers.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.name %></option>
              <% }) %> <% } %>
              <option
                value="new"
                style="font-weight: bold; color: var(--primary)"
              >
                + Create New Supplier
              </option>
            </select>
          </div>

          <div id="newSupplierFields" class="new-fields-container">
            <div class="form-grid">
              <div class="form-group full-width">
                <label>Supplier Name *</label>
                <input
                  type="text"
                  name="new_supplier_name"
                  placeholder="e.g., Global Distributors"
                />
              </div>
              <div class="form-group">
                <label>Email</label>
                <input
                  type="email"
                  name="new_supplier_email"
                  placeholder="sales@supplier.com"
                />
              </div>
              <div class="form-group">
                <label>Phone</label>
                <input
                  type="text"
                  name="new_supplier_phone"
                  placeholder="Contact number"
                />
              </div>
              <div class="form-group full-width">
                <label>Address</label>
                <textarea
                  name="new_supplier_address"
                  rows="2"
                  placeholder="Full office address"
                ></textarea>
              </div>
            </div>
          </div>
        </div>

        <hr />

        <!-- BATCH INFO -->
        <h3>Initial Stock Details</h3>
        <div class="form-grid">
          <div class="form-group">
            <label>Batch Number *</label>
            <input
              type="text"
              name="batch_no"
              placeholder="BN-2024-X"
              required
            />
          </div>

          <div class="form-group">
            <label>Quantity *</label>
            <input
              type="number"
              name="quantity"
              placeholder="Units in stock"
              required
            />
          </div>

          <div class="form-group">
            <label>Cost Price (Per Unit) *</label>
            <input
              type="number"
              step="0.01"
              name="cost_price"
              placeholder="0.00"
              required
            />
          </div>

          <div class="form-group">
            <label>Selling Price (Per Unit) *</label>
            <input
              type="number"
              step="0.01"
              name="selling_price"
              placeholder="0.00"
              required
            />
          </div>

          <div class="form-group">
            <label>Manufacture Date</label>
            <input type="date" name="manufacture_date" />
          </div>

          <div class="form-group">
            <label>Expiry Date *</label>
            <input type="date" name="expiry_date" required />
          </div>
        </div>

        <button type="submit" class="btn-submit">
          💾 Save Medicine & Initialize Stock
        </button>
      </form>
    </div>

    <script>
      // Manufacturer toggle (Functionality preserved)
      const manufacturerSelect = document.getElementById("manufacturerSelect");
      const newManufacturerFields = document.getElementById(
        "newManufacturerFields"
      );

      manufacturerSelect.addEventListener("change", function () {
        if (this.value === "new") {
          newManufacturerFields.style.display = "block";
          document.querySelector(
            'input[name="new_manufacturer_name"]'
          ).required = true;
        } else {
          newManufacturerFields.style.display = "none";
          document.querySelector(
            'input[name="new_manufacturer_name"]'
          ).required = false;
        }
      });

      // Supplier toggle (Functionality preserved)
      const supplierSelect = document.getElementById("supplierSelect");
      const newSupplierFields = document.getElementById("newSupplierFields");

      supplierSelect.addEventListener("change", function () {
        if (this.value === "new") {
          newSupplierFields.style.display = "block";
          document.querySelector(
            'input[name="new_supplier_name"]'
          ).required = true;
        } else {
          newSupplierFields.style.display = "none";
          document.querySelector(
            'input[name="new_supplier_name"]'
          ).required = false;
        }
      });
    </script>
  </body>
</html>
