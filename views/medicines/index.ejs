<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Medicines Inventory - Pharmacy POS</title>
    <!-- Modern Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --primary: #0f766e;
        --primary-light: #14b8a6;
        --accent: #6366f1;
        --bg: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --success: #10b981;
        --warning: #f59e0b;
        --error: #ef4444;
        --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1),
          0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", sans-serif;
        background-color: var(--bg);
        color: var(--text-main);
        line-height: 1.5;
        padding: 20px;
        position: relative;
        min-height: 100vh;
      }

      /* Background Accents */
      .bg-circle {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        z-index: -1;
        opacity: 0.1;
      }
      .circle-1 {
        width: 400px;
        height: 400px;
        background: var(--primary);
        top: -100px;
        left: -100px;
      }
      .circle-2 {
        width: 300px;
        height: 300px;
        background: var(--accent);
        bottom: -50px;
        right: -50px;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
      }

      /* Header Area */
      .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 25px;
        background: white;
        padding: 25px;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
      }

      .page-header h2 {
        font-size: 24px;
        font-weight: 800;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .header-buttons {
        display: flex;
        gap: 10px;
      }

      /* Button Styles */
      .btn {
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      .btn-primary {
        background: var(--primary);
        color: white;
      }
      .btn-primary:hover {
        background: var(--primary-light);
        transform: translateY(-1px);
      }

      .btn-dashboard {
        background: #f1f5f9;
        color: var(--text-main);
      }
      .btn-dashboard:hover {
        background: #e2e8f0;
      }

      .btn-danger {
        background: #fee2e2;
        color: var(--error);
      }
      .btn-danger:hover {
        background: #fecaca;
      }

      .btn-edit {
        background: #ecfdf5;
        color: var(--primary);
      }
      .btn-edit:hover {
        background: #d1fae5;
      }

      /* Search Box */
      .search-card {
        background: white;
        padding: 20px;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        margin-bottom: 25px;
      }

      .search-form {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .search-input {
        flex: 1;
        min-width: 280px;
        padding: 12px 16px;
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        font-family: inherit;
        font-size: 14px;
        background: #f8fafc;
        transition: all 0.2s;
      }

      .search-input:focus {
        outline: none;
        border-color: var(--primary);
        background: white;
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1);
      }

      /* Inventory Table Styling */
      .table-container {
        background: white;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.8);
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
      }

      th {
        background: #f8fafc;
        color: var(--text-muted);
        text-align: left;
        padding: 16px;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.05em;
        border-bottom: 2px solid #f1f5f9;
      }

      td {
        padding: 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: top;
      }

      tr:hover td {
        background-color: #fcfdfe;
      }

      /* Badge Styling */
      .badge {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 700;
        display: inline-block;
      }

      .badge-good {
        background: #dcfce7;
        color: #166534;
      }
      .badge-low {
        background: #fef3c7;
        color: #92400e;
      }
      .badge-expiring {
        background: #ffedd5;
        color: #9a3412;
      }
      .badge-expired {
        background: #fee2e2;
        color: #991b1b;
      }

      /* Batch Item Design */
      .batch-item {
        background: #f8fafc;
        border-radius: 10px;
        padding: 10px;
        margin-bottom: 10px;
        border-left: 4px solid #e2e8f0;
      }

      .batch-item strong {
        color: var(--text-main);
        font-size: 13px;
      }
      .batch-quantity {
        color: var(--primary);
        font-weight: 700;
      }

      /* Mobile Card View (Responsive Table) */
      @media (max-width: 992px) {
        table,
        thead,
        tbody,
        th,
        td,
        tr {
          display: block;
        }
        thead {
          display: none;
        }
        tr {
          border-bottom: 2px solid #f1f5f9;
          padding: 15px;
          position: relative;
        }
        td {
          border: none;
          padding: 8px 0 8px 140px;
          position: relative;
          min-height: 35px;
        }
        td:before {
          content: attr(data-label);
          position: absolute;
          left: 0;
          width: 130px;
          font-weight: 700;
          color: var(--text-muted);
          font-size: 12px;
          text-transform: uppercase;
        }
        .header-buttons {
          width: 100%;
        }
        .btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>

    <div class="container">
      <!-- Page Header -->
      <header class="page-header">
        <h2><span>📦</span> Medicines Inventory</h2>
        <div class="header-buttons">
          <a href="/medicines/create" class="btn btn-primary"
            >+ Add New Medicine</a
          >
          <a href="/dashboard" class="btn btn-dashboard">← Back to Dashboard</a>
        </div>
      </header>

      <!-- Search Section -->
      <div class="search-card">
        <form method="GET" action="/medicines" class="search-form">
          <input
            type="text"
            name="search"
            class="search-input"
            placeholder="Search by name, generic, category..."
            value="<%= search || '' %>"
          />
          <button type="submit" class="btn btn-primary">
            Search Inventory
          </button>
          <% if (search) { %>
          <a href="/medicines" class="btn btn-dashboard">Clear Filter</a>
          <% } %>
        </form>
      </div>

      <!-- Inventory Table -->
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Medicine</th>
              <th>Generic / Category</th>
              <th>Manufacturer</th>
              <th>Batches Info</th>
              <th style="text-align: center">Stock</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (medicines.length === 0) { %>
            <tr>
              <td
                colspan="7"
                style="
                  text-align: center;
                  padding: 50px;
                  color: var(--text-muted);
                "
              >
                <div style="font-size: 40px; margin-bottom: 10px">🔍</div>
                No medicines found in the system.<br />
                <a
                  href="/medicines/create"
                  style="color: var(--primary); font-weight: 700"
                  >Add your first medicine</a
                >
              </td>
            </tr>
            <% } else { %> <% for(var i = 0; i < medicines.length; i++) { var m
            = medicines[i]; %>
            <tr>
              <td data-label="Medicine">
                <strong style="font-size: 15px"><%= m.name %></strong><br />
                <small style="color: var(--text-muted)"><%= m.unit %></small>
              </td>
              <td data-label="Generic/Cat">
                <span style="font-weight: 500"
                  ><%= m.generic_name || '-' %></span
                ><br />
                <small style="color: var(--text-muted)"
                  ><%= m.category || 'General' %></small
                >
              </td>
              <td data-label="Manufacturer">
                <span style="font-size: 13px"
                  ><%= m.manufacturer_name || 'Not Assigned' %></span
                >
              </td>
              <td data-label="Batches Info">
                <% if (m.batches && m.batches.length > 0) { %> <% for(var j = 0;
                j < m.batches.length; j++) { var batch = m.batches[j]; var today
                = new Date(); var expiryDate = new Date(batch.expiry_date); var
                daysToExpiry = Math.ceil((expiryDate - today) / (1000 * 60 * 60
                * 24)); var statusClass = ''; if (daysToExpiry < 0) {
                statusClass = 'badge-expired'; } else if (daysToExpiry <= 30) {
                statusClass = 'badge-expiring'; } else { statusClass =
                'badge-good'; } if (batch.quantity <= 0) { statusClass =
                'badge-expired'; } %>
                <div class="batch-item">
                  <strong>Batch: <%= batch.batch_no %></strong><br />
                  <span class="batch-quantity">Qty: <%= batch.quantity %></span
                  ><br />
                  <small
                    >Exp: <%= new Date(batch.expiry_date).toLocaleDateString()
                    %></small
                  >
                  <span
                    class="badge <%= statusClass %>"
                    style="margin-left: 5px"
                  >
                    <% if (daysToExpiry < 0) { %>Expired <% } else if
                    (daysToExpiry <= 30) { %>Exp: <%= daysToExpiry %>d <% } else
                    if (daysToExpiry <= 90) { %>Exp: <%= daysToExpiry %>d <% }
                    else { %>Active <% } %>
                  </span>
                </div>
                <% } %> <% } else { %>
                <span style="color: var(--text-muted); font-size: 12px italic"
                  >No batches available</span
                ><br />
                <a
                  href="/medicines/edit/<%= m.id %>"
                  class="btn btn-edit"
                  style="font-size: 11px; padding: 4px 8px; margin-top: 5px"
                  >+ Add Batch</a
                >
                <% } %>
              </td>
              <td data-label="Total Stock" style="text-align: center">
                <strong style="font-size: 16px"
                  ><%= m.total_stock || 0 %></strong
                >
              </td>
              <td data-label="Status">
                <% if (m.total_stock <= (m.min_stock_level || 10) &&
                m.total_stock > 0) { %>
                <span class="badge badge-low">Low Stock</span>
                <% } else if (m.total_stock === 0) { %>
                <span class="badge badge-expired">Out of Stock</span>
                <% } else { %>
                <span class="badge badge-good">In Stock</span>
                <% } %>
              </td>
              <td data-label="Actions">
                <div style="display: flex; gap: 5px">
                  <a href="/medicines/edit/<%= m.id %>" class="btn btn-edit"
                    >Edit</a
                  >
                  <form
                    action="/medicines/delete/<%= m.id %>"
                    method="POST"
                    onsubmit="return confirm('Delete this medicine? This will delete all batches too!')"
                  >
                    <button type="submit" class="btn btn-danger">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
            <% } %> <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </body>
</html>
