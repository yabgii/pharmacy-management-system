<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reports & Analytics - Pharmacy System</title>
    <!-- Modern Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --primary: #0f766e;
        --primary-light: #14b8a6;
        --accent: #6366f1;
        --bg: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --success: #10b981;
        --warning: #f59e0b;
        --error: #ef4444;
        --dead: #dc3545;
        --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1),
          0 2px 4px -1px rgba(0, 0, 0, 0.06);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", sans-serif;
        background-color: var(--bg);
        color: var(--text-main);
        line-height: 1.5;
        padding: 20px;
        position: relative;
        min-height: 100vh;
      }

      /* Background Accents */
      .bg-circle {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        z-index: -1;
        opacity: 0.1;
      }
      .circle-1 {
        width: 400px;
        height: 400px;
        background: var(--primary);
        top: -100px;
        left: -100px;
      }
      .circle-2 {
        width: 300px;
        height: 300px;
        background: var(--accent);
        bottom: -50px;
        right: -50px;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
      }

      /* Header Area */
      .header {
        background: white;
        padding: 25px;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        margin-bottom: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
      }

      .header h2 {
        font-size: 24px;
        font-weight: 800;
        color: var(--primary);
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .header-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      /* Button Styles */
      .btn {
        padding: 10px 18px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        transition: all 0.2s;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }

      .btn-success {
        background: var(--success);
        color: white;
      }
      .btn-success:hover {
        background: #059669;
      }

      .btn-dashboard {
        background: #f1f5f9;
        color: var(--text-main);
      }
      .btn-dashboard:hover {
        background: #e2e8f0;
      }

      /* Stats Cards */
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
      }

      .stat-card {
        background: white;
        padding: 24px;
        border-radius: 20px;
        box-shadow: var(--card-shadow);
        border-top: 5px solid transparent;
      }

      .stat-card .icon {
        font-size: 32px;
        margin-bottom: 12px;
      }
      .stat-card h3 {
        font-size: 24px;
        font-weight: 800;
        color: var(--text-main);
      }
      .stat-card p {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .stat-card small {
        font-weight: 700;
        margin-top: 5px;
        display: block;
      }

      .stat-card.revenue {
        border-top-color: var(--success);
      }
      .stat-card.profit {
        border-top-color: var(--accent);
      }
      .stat-card.stock {
        border-top-color: var(--primary-light);
      }
      .stat-card.expiry {
        border-top-color: var(--error);
      }

      /* Layout */
      .two-columns {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
        gap: 24px;
        margin-bottom: 30px;
      }

      .three-columns {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
        margin-bottom: 30px;
      }

      .card {
        background: white;
        border-radius: 20px;
        padding: 24px;
        box-shadow: var(--card-shadow);
        height: fit-content;
      }

      .card h3 {
        font-size: 16px;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-main);
      }

      /* Tables */
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
      }
      th {
        text-align: left;
        background: #f8fafc;
        padding: 12px;
        color: var(--text-muted);
        font-weight: 700;
        font-size: 11px;
        text-transform: uppercase;
      }
      td {
        padding: 12px;
        border-bottom: 1px solid #f1f5f9;
      }
      tr:hover td {
        background-color: #fcfdfe;
      }

      /* Alerts */
      .alert-card {
        padding: 16px;
        border-radius: 12px;
        margin-bottom: 12px;
        font-size: 14px;
      }
      .alert-danger {
        background: #fef2f2;
        color: #991b1b;
        border-left: 4px solid var(--error);
      }
      .alert-warning {
        background: #fffbeb;
        color: #92400e;
        border-left: 4px solid var(--warning);
      }
      .alert-success {
        background: #ecfdf5;
        color: #065f46;
        border-left: 4px solid var(--success);
      }
      .alert-dead {
        background: #fef2f2;
        color: #991b1b;
        border-left: 4px solid var(--dead);
      }

      /* Trend Bars */
      .trend-bars {
        margin-top: 15px;
      }
      .trend-bar {
        display: flex;
        align-items: center;
        margin-bottom: 15px;
      }
      .trend-bar .date {
        width: 120px;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-muted);
      }
      .trend-bar .bar-container {
        flex: 1;
        height: 32px;
        background: #f1f5f9;
        border-radius: 8px;
        overflow: hidden;
        margin: 0 15px;
        position: relative;
      }
      .trend-bar .bar {
        height: 100%;
        background: linear-gradient(
          90deg,
          var(--primary-light),
          var(--primary)
        );
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: 12px;
        color: white;
        font-size: 11px;
        font-weight: 700;
        transition: width 1s ease-in-out;
      }
      .trend-bar .value {
        width: 70px;
        font-size: 12px;
        font-weight: 700;
        text-align: right;
      }

      /* Payment Method Colors */
      .payment-cash {
        background: #10b981;
        color: white;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        display: inline-block;
      }
      .payment-cbe {
        background: #1e40af;
        color: white;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        display: inline-block;
      }
      .payment-telebirr {
        background: #f59e0b;
        color: white;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        display: inline-block;
      }
      .payment-other {
        background: #6b7280;
        color: white;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        display: inline-block;
      }

      .profit-positive {
        color: var(--success);
        font-weight: 700;
      }
      .profit-negative {
        color: var(--error);
        font-weight: 700;
      }
      .dead-amount {
        color: var(--dead);
        font-weight: 700;
      }

      @media (max-width: 768px) {
        .header {
          flex-direction: column;
          text-align: center;
        }
        .header-actions {
          width: 100%;
          justify-content: center;
        }
        .two-columns,
        .three-columns {
          grid-template-columns: 1fr;
        }
        .trend-bar .date {
          width: 80px;
        }
      }
    </style>
  </head>
  <body>
    <div class="bg-circle circle-1"></div>
    <div class="bg-circle circle-2"></div>

    <div class="container">
      <!-- Header -->
      <div class="header">
        <h2><span>📊</span> Analytics & Reports</h2>
        <div class="header-actions">
          <a href="/reports/export" class="btn btn-success">📥 Export CSV</a>
          <a href="/dashboard" class="btn btn-dashboard">← Back to Dashboard</a>
        </div>
      </div>

      <!-- Key Metrics -->
      <div class="stats-grid">
        <div class="stat-card revenue">
          <div class="icon">💰</div>
          <p>Today's Revenue</p>
          <h3>ETB <%= (todayRevenue || 0).toLocaleString() %></h3>
          <small style="color: var(--success)"
            >+ETB <%= (todayProfit || 0).toLocaleString() %> profit</small
          >
        </div>
        <div class="stat-card profit">
          <div class="icon">📈</div>
          <p>Month's Revenue</p>
          <h3>ETB <%= (monthRevenue || 0).toLocaleString() %></h3>
          <small style="color: var(--accent)"
            >ETB <%= (monthProfit || 0).toLocaleString() %> profit</small
          >
        </div>
        <div class="stat-card stock">
          <div class="icon">📦</div>
          <p>Units in Stock</p>
          <h3><%= totalUnits || 0 %></h3>
          <small style="color: var(--primary-light)"
            >ETB <%= (totalInvestment || 0).toLocaleString() %> invested</small
          >
        </div>
        <div class="stat-card expiry">
          <div class="icon">⚠️</div>
          <p>At Risk (30 Days)</p>
          <h3><%= expiring30Batches || 0 %> Batches</h3>
          <small style="color: var(--error)"
            >ETB <%= (expiring30Value || 0).toLocaleString() %> at risk</small
          >
        </div>
      </div>

      <!-- Main Layout -->
      <div class="two-columns">
        <!-- Left Column -->
        <div>
          <!-- Stock Value Card -->
          <div class="card">
            <h3>📈 Stock Value Summary</h3>
            <table>
              <tr>
                <td>Total Investment (Cost)</td>
                <td class="text-right">
                  <strong
                    >ETB <%= (totalInvestment || 0).toLocaleString() %></strong
                  >
                </td>
              </tr>
              <tr>
                <td>Potential Revenue</td>
                <td class="text-right">
                  <strong
                    >ETB <%= (totalPotentialRevenue || 0).toLocaleString()
                    %></strong
                  >
                </td>
              </tr>
              <tr>
                <td class="profit-positive">Potential Profit</td>
                <td class="text-right profit-positive">
                  ETB <%= (totalPotentialProfit || 0).toLocaleString() %>
                </td>
              </tr>
              <tr>
                <td>Avg Profit Margin</td>
                <td class="text-right">
                  <strong
                    ><%= (typeof avgMargin === 'number' ? avgMargin :
                    0).toFixed(1) %>%</strong
                  >
                </td>
              </tr>
            </table>
          </div>

          <!-- Expiry Alerts -->
          <div class="card">
            <h3>⚠️ Expiry Alerts</h3>
            <% if (expiring30Batches > 0) { %>
            <div class="alert-card alert-warning">
              <strong><%= expiring30Batches %> batches</strong> expiring within
              30 days<br />
              At risk:
              <strong
                >ETB <%= (expiring30Value || 0).toLocaleString() %></strong
              >
              <br /><a
                href="/batches?status=expiring"
                style="
                  color: #92400e;
                  font-weight: 700;
                  text-decoration: none;
                  font-size: 12px;
                "
              >
                Manage expiring batches →
              </a>
            </div>
            <% } %> <% if (expiredBatches > 0) { %>
            <div class="alert-card alert-danger">
              <strong><%= expiredBatches %> batches</strong> have expired!<br />
              Total loss:
              <strong>ETB <%= (expiredValue || 0).toLocaleString() %></strong>
              <br /><a
                href="/batches?status=expired"
                style="
                  color: #991b1b;
                  font-weight: 700;
                  text-decoration: none;
                  font-size: 12px;
                "
              >
                Manage expired batches →
              </a>
            </div>
            <% } %> <% if (expiring30Batches === 0 && expiredBatches === 0) { %>
            <div class="alert-card alert-success">
              ✅ All batches are healthy! No expiry alerts.
            </div>
            <% } %>
          </div>

          <!-- Stock Alerts -->
          <div class="card">
            <h3>📦 Stock Level Alerts</h3>
            <% if (lowStockItems && lowStockItems.length > 0) { %>
            <h4
              style="
                margin: 10px 0 10px;
                color: var(--warning);
                font-size: 13px;
              "
            >
              🔴 Low Stock
            </h4>
            <% lowStockItems.forEach(function(item) { %>
            <div class="alert-card alert-warning" style="padding: 10px">
              <strong><%= item.name %></strong>: <%= item.current_stock %> left
              (Min: <%= item.min_stock_level %>)
            </div>
            <% }) %> <% } %> <% if (outOfStockItems && outOfStockItems.length >
            0) { %>
            <h4
              style="margin: 15px 0 10px; color: var(--error); font-size: 13px"
            >
              ❌ Out of Stock
            </h4>
            <% outOfStockItems.forEach(function(item) { %>
            <div class="alert-card alert-danger" style="padding: 10px">
              <strong><%= item.name %></strong> - Out of stock!<br />
              <a
                href="/medicines/edit/<%= item.id %>"
                style="
                  color: #991b1b;
                  font-weight: 700;
                  text-decoration: none;
                  font-size: 12px;
                "
              >
                Restock Now →
              </a>
            </div>
            <% }) %> <% } %> <% if ((!lowStockItems || lowStockItems.length ===
            0) && (!outOfStockItems || outOfStockItems.length === 0)) { %>
            <div class="alert-card alert-success">
              ✅ Stock levels are healthy!
            </div>
            <% } %>
          </div>
        </div>

        <!-- Right Column -->
        <div>
          <!-- Weekly Sales Trend -->
          <div class="card">
            <h3>📅 Weekly Sales Trend</h3>
            <div class="trend-bars">
              <% if (weeklyTrend && weeklyTrend.length > 0) { const maxRevenue =
              Math.max(...weeklyTrend.map(d => d.revenue), 1); %> <%
              weeklyTrend.forEach(function(day) { const percentage =
              (day.revenue / maxRevenue) * 100; %>
              <div class="trend-bar">
                <span class="date"
                  ><%= new Date(day.date).toLocaleDateString('en-US', { weekday:
                  'short', day: 'numeric' }) %></span
                >
                <div class="bar-container">
                  <div class="bar" style="width: <%= percentage %>%">
                    ETB <%= (day.revenue || 0).toLocaleString() %>
                  </div>
                </div>
                <span class="value"><%= day.transactions || 0 %> sales</span>
              </div>
              <% }) %> <% } else { %>
              <p
                style="
                  text-align: center;
                  color: var(--text-muted);
                  font-size: 13px;
                  padding: 20px;
                "
              >
                No sales data available for this week.
              </p>
              <% } %>
            </div>
          </div>

          <!-- Top Medicines -->
          <div class="card">
            <h3>🏆 Top Medicines (This Month)</h3>
            <table>
              <thead>
                <tr>
                  <th>Medicine</th>
                  <th>Qty</th>
                  <th>Profit</th>
                </tr>
              </thead>
              <tbody>
                <% if (topSelling && topSelling.length > 0) { %> <%
                topSelling.forEach(function(item) { %>
                <tr>
                  <td>
                    <strong><%= item.name %></strong><br /><small
                      ><%= item.unit %></small
                    >
                  </td>
                  <td><%= item.total_sold %></td>
                  <td class="profit-positive">
                    ETB <%= (item.total_profit || 0).toLocaleString() %>
                  </td>
                </tr>
                <% }) %> <% } else { %>
                <tr>
                  <td colspan="3" style="text-align: center">
                    No sales data available
                  </td>
                </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- NEW: Three Columns for Dead Stock, Peak Hours, Payment Methods -->
      <div class="three-columns">
        <!-- Dead Stock Card -->
        <div class="card">
          <h3>💀 Dead Stock (Slow Moving)</h3>
          <p
            style="
              font-size: 12px;
              color: var(--text-muted);
              margin-bottom: 15px;
            "
          >
            Items not sold in the last 90 days - Capital tied up
          </p>
          <% if (deadStock && deadStock.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Medicine</th>
                <th>Stock</th>
                <th>Capital Frozen</th>
                <th>Last Sale</th>
              </tr>
            </thead>
            <tbody>
              <% deadStock.slice(0, 5).forEach(function(item) { %>
              <tr>
                <td>
                  <strong><%= item.name %></strong><br /><small
                    ><%= item.unit %></small
                  >
                </td>
                <td><%= item.stock_quantity %></td>
                <td class="dead-amount">
                  ETB <%= parseFloat(item.capital_tied_up).toLocaleString() %>
                </td>
                <td><%= item.days_since_last_sale %> days ago</td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% if (deadStock.length > 5) { %>
          <p style="text-align: center; margin-top: 10px">
            <small>+ <%= deadStock.length - 5 %> more items</small>
          </p>
          <% } %>
          <div class="alert-card alert-dead" style="margin-top: 15px">
            <strong
              >Total Frozen Capital: ETB <%= (deadStockTotal ||
              0).toLocaleString() %></strong
            >
          </div>
          <% } else { %>
          <div class="alert-card alert-success">
            ✅ No dead stock! All items are moving well.
          </div>
          <% } %>
        </div>

        <!-- Peak Hours Card -->
        <div class="card">
          <h3>⏰ Peak Hours Analysis</h3>
          <p
            style="
              font-size: 12px;
              color: var(--text-muted);
              margin-bottom: 15px;
            "
          >
            Sales volume by hour - Optimize staff scheduling
          </p>
          <% if (peakHours && peakHours.length > 0) { var maxTransactions = 0;
          peakHours.forEach(function(h) { if(h.transactions > maxTransactions)
          maxTransactions = h.transactions; }); %>
          <div style="margin-bottom: 15px">
            <strong>🏆 Peak Hour:</strong>
            <% for(var i = 0; i < peakHours.length; i++) {
            if(peakHours[i].transactions === maxTransactions && maxTransactions
            > 0) { %>
            <span
              style="
                background: #17a2b8;
                color: white;
                padding: 4px 12px;
                border-radius: 20px;
                font-size: 13px;
              "
            >
              <%= peakHours[i].hour %>:00 - <%= peakHours[i].hour+1 %>:00 (<%=
              peakHours[i].transactions %> sales)
            </span>
            <% } %> <% } %>
          </div>
          <div class="trend-bars">
            <% peakHours.forEach(function(hour) { var width = (hour.transactions
            / maxTransactions) * 100; if (maxTransactions === 0) width = 0; %>
            <div class="trend-bar">
              <span class="date" style="width: 70px"><%= hour.hour %>:00</span>
              <div class="bar-container" style="margin: 0 8px">
                <div
                  class="bar"
                  style="
                    width: <%= width %>%;
                    background: linear-gradient(90deg, #f59e0b, #dc3545);
                  "
                >
                  <%= hour.transactions %> sales
                </div>
              </div>
              <span class="value" style="width: 90px"
                >ETB <%= hour.revenue.toLocaleString() %></span
              >
            </div>
            <% }); %>
          </div>
          <% } else { %>
          <div class="alert-card alert-warning">
            No sales data available for peak hour analysis.
          </div>
          <% } %>
        </div>

        <!-- Payment Methods Card -->
        <div class="card">
          <h3>💳 Payment Methods</h3>
          <p
            style="
              font-size: 12px;
              color: var(--text-muted);
              margin-bottom: 15px;
            "
          >
            Revenue distribution by payment type (Last 30 days)
          </p>
          <% if (paymentBreakdown && paymentBreakdown.length > 0) { var
          paymentColors = { cash: 'payment-cash', cbe: 'payment-cbe', telebirr:
          'payment-telebirr', other: 'payment-other' }; var paymentIcons = {
          cash: '💵', cbe: '🏦', telebirr: '📱', other: '🔄' }; %>
          <table>
            <thead>
              <tr>
                <th>Method</th>
                <th>Transactions</th>
                <th>Amount</th>
                <th>%</th>
              </tr>
            </thead>
            <tbody>
              <% paymentBreakdown.forEach(function(method) { %>
              <tr>
                <td>
                  <span
                    class="<%= paymentColors[method.payment_method] || 'payment-other' %>"
                  >
                    <%= paymentIcons[method.payment_method] || '💰' %> <%=
                    method.payment_method.toUpperCase() %>
                  </span>
                </td>
                <td><%= method.transaction_count %></td>
                <td>
                  ETB <%= parseFloat(method.total_amount).toLocaleString() %>
                </td>
                <td><strong><%= method.percentage %>%</strong></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <div
            style="
              margin-top: 15px;
              padding: 12px;
              background: #f8f9fa;
              border-radius: 12px;
            "
          >
            <strong>Today's Collection:</strong> ETB <%= (todayPaymentTotal ||
            0).toLocaleString() %>
          </div>
          <% } else { %>
          <div class="alert-card alert-warning">
            No payment data available for the selected period.
          </div>
          <% } %>
        </div>
      </div>

      <!-- Recent Activities -->
      <div class="card" style="margin-bottom: 30px">
        <h3>🔄 Audit Log (Recent Activities)</h3>
        <table>
          <thead>
            <tr>
              <th>Time</th>
              <th>User</th>
              <th>Activity</th>
            </tr>
          </thead>
          <tbody>
            <% if (recentActivities && recentActivities.length > 0) { %> <%
            recentActivities.forEach(function(activity) { %>
            <tr>
              <td>
                <small><%= new Date(activity.date).toLocaleString() %></small>
              </td>
              <td><strong><%= activity.user_name || 'System' %></strong></td>
              <td><small><%= activity.description %></small></td>
            </tr>
            <% }) %> <% } else { %>
            <tr>
              <td colspan="3" style="text-align: center">
                No activity recorded.
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
